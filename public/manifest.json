{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_app_extension_name__",
  "version": "2.6.1",
  "description": "__MSG_app_extension_description__",
  "permissions": [
    "tabs",
    "tabGroups",
    "sidePanel",
    "favicon",
    "storage",
    "alarms"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "__MSG_app_action_title__"
  }
}
