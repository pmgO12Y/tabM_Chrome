{
  "name": "tabM_Chrome",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "npm run typecheck:app && vite build",
    "test": "vitest run",
    "e2e": "npx playwright test",
    "e2e:ui": "npx playwright test --ui",
    "e2e:install": "npx playwright install chromium",
    "typecheck": "npm run typecheck:app && npm run typecheck:test && npm run typecheck:node",
    "typecheck:app": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "lint": "eslint src/ tests/",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"tests/**/*.ts\"",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@icon-park/react": "^1.4.2",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/chrome": "0.0.314",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.8.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "8.59.1",
    "vite": "7.3.2",
    "vitest": "3.1.3"
  }
}
